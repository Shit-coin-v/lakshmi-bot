!backend_bot/.env.example

# ========================
# APP (Flutter / Dart)
# Пути относительно папки app/
# ========================
app/.dart_tool/
app/.flutter-plugins-dependencies
app/.pub-cache/
app/.pub/
app/build/
app/coverage/
app/migrate_working_dir/

# iOS / Mac specific in Flutter
app/.atom/
app/.build/
app/.buildlog/
app/.swiftpm/
app/**/*.class
app/**/doc/api/
app/**/ios/Flutter/.last_build_id

# Symbolication & Obfuscation
app/app.*.symbols
app/app.*.map.json

# Android Studio artifacts
app/android/app/debug
app/android/app/profile
app/android/app/release
