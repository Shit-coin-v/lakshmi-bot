# ========================
.DS_Store
*.log
*.swp
*.bak
*.bak.*
.history
.svn/

# IDE & Editors (JetBrains, VS Code)
.idea/
*.iml
*.ipr
*.iws
.vscode/

# ========================
# BACKEND (Python / Django)
# Пути относительно папки backend_bot/
# ========================
# Byte-compiled / Optimized / DLL files
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Database
*.sqlite3

# Environments & Secrets
backend_bot/.env
backend_bot/.env.*
backend_bot/*.env
backend_bot/venv/
backend_bot/.venv/
backend_bot/backend/venv/

# Django specific
backend_bot/media/
backend_bot/staticfiles/
backend_bot/backend/collected_static/

# Development specific
backend_bot/src/qr_codes/

# Исключение для примера (если нужно, чтобы .env.example был виден)
!backend_bot/.env.example

# ========================
# APP (Flutter / Dart)
# Пути относительно папки mobile/flutter_app/
# ========================
mobile/flutter_app/.dart_tool/
mobile/flutter_app/.flutter-plugins-dependencies
mobile/flutter_app/.pub-cache/
mobile/flutter_app/.pub/
mobile/flutter_app/build/
mobile/flutter_app/coverage/
mobile/flutter_app/migrate_working_dir/

# iOS / Mac specific in Flutter
mobile/flutter_app/.atom/
mobile/flutter_app/.build/
mobile/flutter_app/.buildlog/
mobile/flutter_app/.swiftpm/
mobile/flutter_app/**/*.class
mobile/flutter_app/**/doc/api/
mobile/flutter_app/**/ios/Flutter/.last_build_id

# Symbolication & Obfuscation
mobile/flutter_app/app.*.symbols
mobile/flutter_app/app.*.map.json

# Android Studio artifacts
mobile/flutter_app/android/app/debug
mobile/flutter_app/android/app/profile
mobile/flutter_app/android/app/release

# Secrets
backend_bot/backend/firebase_service_account.json

# Python venv
backend_bot/venv/

# Python cache
**/__pycache__/
*.pyc
