__pycache__/
*.py[cod]
*.pyo
*.pyd

# Database
*.sqlite3

# Environments & Secrets
backend_bot/.env
backend_bot/.env.*
backend_bot/*.env
backend_bot/venv/
backend_bot/.venv/
backend_bot/backend/venv/

# Django specific
backend_bot/media/
backend_bot/staticfiles/
backend_bot/backend/collected_static/

