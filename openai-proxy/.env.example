# --- OpenAI Proxy ---
# Реальные значения класть в .env (не коммитить).
# .env.example — единственный committable файл с переменными.

# Ключ OpenAI API. Хранится ТОЛЬКО здесь, в Django/photo-studio не должен попадать.
OPENAI_API_KEY=sk-replace-me

# Внутренний ключ для аутентификации запросов от Django backend.
# Должен совпадать с OPENAI_PROXY_API_KEY на стороне Django.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(48))"
INTERNAL_API_KEY=

# Таймаут запроса к OpenAI (секунды). Должен быть <= таймаута upstream.
OPENAI_REQUEST_TIMEOUT=120

# Максимальный размер входного изображения, байты. Защита от DoS.
MAX_IMAGE_SIZE_BYTES=10485760

# Уровень логирования: DEBUG / INFO / WARNING / ERROR.
LOG_LEVEL=INFO

# Порт, на котором слушает uvicorn внутри контейнера.
PROXY_PORT=8080
