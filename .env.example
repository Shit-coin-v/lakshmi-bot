# ===== Telegram =====
BOT_TOKEN=CHANGE_ME_TELEGRAM_BOT_TOKEN
GUEST_TELEGRAM_ID=0

# ===== Django =====
DEBUG=False
SECRET_KEY=CHANGE_ME_DJANGO_SECRET_KEY
# Перечисли домены через запятую (без пробелов)
ALLOWED_HOSTS=your-domain.tld,localhost,127.0.0.1
# Используется nginx шаблоном для server_name
SERVER_NAME=_
# Origins должны включать протокол. Для прод-домена оставь https://
CSRF_TRUSTED_ORIGINS=https://your-domain.tld
DJANGO_DB_CONN_MAX_AGE=60
DJANGO_LOG_LEVEL=INFO
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=False
# Для production поставь True
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
DJANGO_SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# ===== Redis =====
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ===== Celery =====
# URL должен содержать пароль Redis
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# ===== Database (Django + docker-compose) =====
POSTGRES_HOST=db
POSTGRES_DB=lakshmi
POSTGRES_USER=lakshmi
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_PORT=5432
# При необходимости включи SSL: например, require
# POSTGRES_SSLMODE=require

# ===== Monitoring dashboards =====
# Укажи публичный URL c протоколом, чтобы Grafana/Metabase корректно работали за прокси
PUBLIC_BASE_URL=http://localhost:8000
GRAFANA_ADMIN_USER=change-me
GRAFANA_ADMIN_PASSWORD=change-me-please

# ===== Docker Compose runtime =====
DJANGO_SETTINGS_MODULE=settings
PYTHONPATH=/app/backend
MB_DB_FILE=/metabase-data/metabase.db
MB_JETTY_HOST=0.0.0.0
MB_JETTY_PORT=3000
MB_SITE_URL=https://your-domain.tld/metabase/

# ===== Gunicorn / runtime =====
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=60
ENABLE_TELEGRAM_BOT=true

# ===== 1C integration =====
# API key обязателен, список IP можно ограничить через маски типа 192.168.*
INTEGRATION_API_KEY=CHANGE_ME_INTEGRATION_KEY
ONEC_ORDER_URL=CHANGE_ME_ONEC_ORDER_URL
ONEC_ALLOW_IPS=

# ===== Firebase / Push notifications =====
# Укажи либо JSON blob сервисного аккаунта, либо путь до файла.
FIREBASE_SERVICE_ACCOUNT_JSON=CHANGE_ME_FIREBASE_JSON
# FIREBASE_SERVICE_ACCOUNT_PATH=/app/backend/firebase_service_account.json

# ===== Courier Bot =====
COURIER_BOT_TOKEN=CHANGE_ME_COURIER_BOT_TOKEN
STORE_LOCATION=село Намцы
# COURIER_ALLOWED_TG_IDS — DEPRECATED: доступ управляется через Django Admin (CourierProfile)

# ===== Picker Bot =====
PICKER_BOT_TOKEN=CHANGE_ME_PICKER_BOT_TOKEN
# PICKER_ALLOWED_TG_IDS — DEPRECATED: доступ управляется через Django Admin (PickerProfile)
